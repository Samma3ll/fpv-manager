# Database Configuration
POSTGRES_USER=fpv_admin
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=fpv_manager
DATABASE_URL=postgresql+asyncpg://fpv_admin:change_me_in_production@postgres:5432/fpv_manager

# Redis Configuration
REDIS_URL=redis://redis:6379

# MinIO Configuration (S3-compatible Object Storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_REGION=us-east-1
MINIO_BUCKET_BLACKBOX_LOGS=blackbox-logs
MINIO_BUCKET_ASSETS=assets
# API endpoint from outside container (for presigned URLs)
MINIO_PUBLIC_URL=http://minio:9000

# Backend FastAPI Configuration
SECRET_KEY=change_me_in_production_with_a_long_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ENVIRONMENT=development
DEBUG=True
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# Frontend Configuration
VITE_API_URL=http://localhost:8000
FRONTEND_PORT=5173

# Betaflight & Logging
BETAFLIGHT_PARSER=orangebox
LOG_LEVEL=DEBUG

# Worker Configuration (Celery)
CELERY_BROKER_URL=redis://redis:6379
CELERY_RESULT_BACKEND=redis://redis:6379
CELERY_WORKER_CONCURRENCY=4
